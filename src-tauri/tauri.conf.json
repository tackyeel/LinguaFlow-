{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinguaFlow",
  "version": "0.1.0",
  "identifier": "com.linguaflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "settings",
        "title": "LinguaFlow 设置",
        "url": "/",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620,
        "center": true,
        "visible": false,
        "resizable": true,
        "decorations": true
      },
      {
        "label": "translate",
        "title": "LinguaFlow 翻译",
        "url": "/",
        "width": 520,
        "height": 420,
        "minWidth": 420,
        "minHeight": 340,
        "center": true,
        "visible": false,
        "resizable": true,
        "decorations": true
      },
      {
        "label": "hotkey-recorder",
        "title": "设置快捷键",
        "url": "/",
        "width": 460,
        "height": 320,
        "center": true,
        "visible": false,
        "resizable": false,
        "decorations": true
      },
      {
        "label": "screenshot-overlay",
        "title": "截图 / OCR",
        "url": "/",
        "width": 900,
        "height": 640,
        "center": true,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "transparent": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
